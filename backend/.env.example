# Server config
PORT=5001
NODE_ENV=development

# Database connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nudgedm?schema=public"

# Better Auth secret and URL
BETTER_AUTH_SECRET="some_very_long_random_string_here_32_chars"
BETTER_AUTH_URL="http://localhost:5001"

# Encryption Key for sensitive fields (e.g. Access Tokens) - MUST be 32 bytes (64 hex characters)
ENCRYPTION_KEY="0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef"

# Meta (Facebook/Instagram) Developer Config
FB_CLIENT_ID="mock_fb_client_id"
FB_CLIENT_SECRET="mock_fb_client_secret"
FB_REDIRECT_URI="http://localhost:5001/instagram/callback"
FB_APP_SECRET="mock_fb_app_secret"

# Stripe Config
STRIPE_SECRET_KEY="sk_test_mock"
STRIPE_WEBHOOK_SECRET="whsec_mock"
STRIPE_STARTER_PRICE_ID="price_starter_mock"
STRIPE_PRO_PRICE_ID="price_pro_mock"

# Resend API Key
RESEND_API_KEY="re_mock"

# Sandbox / Simulation Mode (set to true to run webhook logic, OAuth, & Stripe without real APIs)
SANDBOX_MODE=true
